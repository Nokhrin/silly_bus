#!/bin/bash

echo "🚀 Запуск pre-commit проверок..."

# 1. Проверка на наличие шумовых файлов в индексе
NOISY_FILES=$(git diff --cached --name-only | grep -E "dependency-reduced-pom\.xml$|asm_string_app$")
if [ -n "$NOISY_FILES" ]; then
    echo "❌ ОШИБКА: Обнаружены файлы, которые не должны коммититься:"
    echo "$NOISY_FILES"
    echo "Добавьте их в .gitignore и выполните 'git rm --cached <файл>'"
    exit 1
fi

# 2. Проверка компиляции (перехват ошибки CI)
# Проверяем, были ли изменены Java-файлы или файлы грамматики ANTLR
CHANGED_FILES=$(git diff --cached --name-only | grep -E "\.(java|g4|xml)$")

if [ -n "$CHANGED_FILES" ]; then
    echo "🔨 Выполняется компиляция для проверки ошибок..."

    # Запускаем компиляцию в тихом режиме. Если ошибка, вывод будет показан.
    # -q подавляет успешный вывод, но покажет ошибки при сбое.
    mvn compile -q -DskipTests
    COMPILE_STATUS=$?

    if [ $COMPILE_STATUS -ne 0 ]; then
        echo ""
        echo "❌ ОШИБКА КОМПИЛЯЦИИ!"
        echo "Коммит отклонен. Пожалуйста, исправьте ошибки компиляции перед коммитом."
        echo "💡 Подсказка: запустите 'mvn compile' вручную, чтобы увидеть полный лог."
        exit 1
    fi
fi

echo "✅ Pre-commit проверки успешно пройдены."
exit 0