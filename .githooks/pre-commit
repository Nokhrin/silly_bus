#!/bin/bash
set -e

CHANGED_FILES=$(git diff --cached --name-only | grep -E "\.(java|g4|xml)$")
if [ -n "$CHANGED_FILES" ]; then
    echo "Выполняется компиляция для проверки синтаксиса..."
    if ! mvn compile -q -DskipTests; then
        echo "Ошибка компиляции. Коммит отклонен."
        echo "Запустите 'mvn compile' вручную для просмотра полного лога."
        exit 1
    fi
fi

exit 0