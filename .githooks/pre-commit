#!/bin/bash
set -e

CHANGED_FILES=$(git diff --cached --name-only | grep -E "\.(java|g4|xml)$" || true)

if [ -n "$CHANGED_FILES" ]; then
    echo "Running compilation check for syntax validation"

    if ! mvn compile -q -DskipTests; then
        echo "Compilation failed. Commit rejected."
        echo "Run 'mvn compile' manually to view the full error log."
        exit 1
    fi
fi

exit 0